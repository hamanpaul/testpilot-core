+                capture_output=True,
+                text=True,
+                timeout=5,
+            )
+            if result.returncode == 0 and result.stdout.strip():
+                print(
+                    "WARN: testpilot still importable outside the managed venv: "
+                    f"{result.stdout.strip()}",
+                    file=sys.stderr,
+                )
+        except Exception:
+            pass
+
+    print("Legacy migration complete.")
